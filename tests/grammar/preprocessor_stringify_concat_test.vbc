// 测试点：# 字符串化与 ## 拼接宏运算符。

#include "../preprocessor_stringify_macros.inc"

#define STR(x) #x
#define CAT(a, b) a ## b
#define MKSTR(x) #x
#define F(a) MKSTR(a)
#define ONE 1
#define X ONE
#define foobar 42
#define BIT(n) (1 ## n)

int main() {
    int score = 0;

    string s1 = STR(hello);

    string s2 = STR(a + 1);

    string s3 = STR("q");

    int v1 = CAT(1, 2);
    if (v1 == 12) {
        score = score + 8;
    }

    int v2 = CAT(foo, bar);
    if (v2 == 42) {
        score = score + 16;
    }

    string s4 = MKSTR(X);

    string s5 = F(X);

    string s6 = INC_STR(world);

    int v3 = INC_CAT(3, 4);
    if (v3 == 34) {
        score = score + 256;
    }

    int v4 = BIT(0);
    if (v4 == 10) {
        score = score + 512;
    }

    write(STDOUT, "\n=== Stringify Concat Preprocessor Test ===\n");
    write(STDOUT, "score: ");
    write(STDOUT, score);
    write(STDOUT, "\n");

    // 期望 score = 8+16+256+512 = 792
    return score;
}

main();
