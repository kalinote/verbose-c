// 测试点：IR lowering 负向样例；当前 MVP 不为循环赋值合流生成 phi。
// 用法：普通运行应成功；`--dump ir` 应给出“栈状态不一致”的明确诊断。

int main() {
    int index = 0;
    int total = 0;

    while (index < 3) {
        total = total + index;
        index = index + 1;
    }

    write(STDOUT, "\n=== IR Unsupported Loop Stack Test ===\n");
    write(STDOUT, "total = ");
    write(STDOUT, total);
    write(STDOUT, "\n");

    return total;
}

main();
