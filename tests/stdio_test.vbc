// 测试点：使用内置 STDIN/STDOUT 常量与 read/write 函数完成标准输入输出。

// STDOUT 的文件描述符是 1
write(STDOUT, "\n=== Standard I/O Test ===\n");
write(STDOUT, "Please enter your name: ");

// STDIN 的文件描述符是 0
// 从标准输入读取最多 1024 个字节
string name = read(STDIN, 1024);

write(STDOUT, "\nHello, ");
write(STDOUT, name);
write(STDOUT, "Welcome to the new I/O system!\n");
