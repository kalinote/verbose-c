// 测试点：if/else if/else、while、do while、for、break 和 continue。

int main() {
    write(STDOUT, "\n=== Control Flow Grammar Test ===\n");

    int total = 0;
    int index = 0;

    if (total == 0) {
        total = 1;
    } else if (total < 0) {
        total = 2;
    } else {
        total = 3;
    }
    write(STDOUT, "total after if/else: ");
    write(STDOUT, total);
    write(STDOUT, "\n");

    while (index < 5) {
        index = index + 1;
        if (index == 2) {
            continue;
        }
        if (index == 4) {
            break;
        }
        total = total + index;
    }
    write(STDOUT, "total after while: ");
    write(STDOUT, total);
    write(STDOUT, ", index: ");
    write(STDOUT, index);
    write(STDOUT, "\n");

    do {
        total = total - 1;
    } while (total > 0);
    write(STDOUT, "total after do while: ");
    write(STDOUT, total);
    write(STDOUT, "\n");

    for (int i = 0; i < 3; i = i + 1) {
        total = total + i;
    }
    write(STDOUT, "total after for with initializer declaration: ");
    write(STDOUT, total);
    write(STDOUT, "\n");

    for (; total < 10; total = total + 1) {
        if (total == 8) {
            break;
        }
    }
    write(STDOUT, "total after for without initializer: ");
    write(STDOUT, total);
    write(STDOUT, "\n");

    return total;
}

main();
