// 测试点：指针声明、null 初始化、取地址、解引用读取与解引用写入。

int main() {
    int a = 10;
    int* p = null;

    write(STDOUT, "\n=== Pointer Execution Test ===\n");
    write(STDOUT, "Initial a: ");
    write(STDOUT, (string)a);
    write(STDOUT, "\n");
    write(STDOUT, "Initial p: ");
    write(STDOUT, p);
    write(STDOUT, "\n");

    // 取地址运算符 (&)
    p = &a;
    write(STDOUT, "\np after p = &a: ");
    write(STDOUT, p);
    write(STDOUT, "\n");

    // 解引用读取 (*)
    int b = *p;
    write(STDOUT, "\nb after b = *p: ");
    write(STDOUT, b);
    write(STDOUT, "\n");

    // 解引用写入 (*)
    *p = 20;
    write(STDOUT, "\na after *p = 20: ");
    write(STDOUT, a);
    write(STDOUT, "\n");
    write(STDOUT, "Current *p: ");
    write(STDOUT, *p);
    write(STDOUT, "\n");

    return 0;
}

main();
