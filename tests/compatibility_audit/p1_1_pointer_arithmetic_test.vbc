// P1-1 指针算术：数组衰变、指针加减、自增和差值。

int main() {
    int arr[4] = {1, 2, 3, 4};
    int* p = arr;

    if (*(arr + 2) != 3) {
        return 1;
    }
    if (*(p + 1) != 2) {
        return 2;
    }

    p++;
    if (*p != 2) {
        return 3;
    }

    p += 2;
    if (*p != 4) {
        return 4;
    }

    p -= 1;
    if (*p != 3) {
        return 5;
    }
    if ((p - arr) != 2) {
        return 6;
    }

    return 0;
}
